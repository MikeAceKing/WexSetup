{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../web/index.html",
    "distDir": "../web",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Wexio Desktop",
    "version": "1.0.1"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "open": true
      },
      "window": {
        "create": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Business",
      "identifier": "be.wexio.desktop",
      "publisher": "Wexio",
      "targets": [
        "nsis",
        "msi",
        "dmg",
        "appimage"
      ],
      "icon": [
        "icons/icon.ico",
        "icons/icon.icns",
        "icons/icon.png"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Wexio Desktop",
        "width": 1600,
        "height": 1000,
        "maximized": true,
        "resizable": true,
        "decorations": false,
        "transparent": false
      }
    ]
  }
}
